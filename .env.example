NEXT_PUBLIC_APP_URL=https://todos-sejam-um.vercel.app
CRON_SECRET=REDACTED_cron_secret_aleatorio_min_32_caracteres
ADMIN_PASSWORD=REDACTED_senha_admin_bem_forte

# ===== Banco de dados (Neon PostgreSQL) =====
DATABASE_URL=REDACTED_DATABASE_URL

# ===== Groq (conteúdo + análise de ressonância) =====
GROQ_API_KEY=

# ===== Neon Auth (Google Login) =====
NEON_AUTH_BASE_URL=https://seu-projeto.neonauth.sa-east-1.aws.neon.tech/neondb/auth
