# =========================================
# RCT PLATAFORMA — EXEMPLO DE AMBIENTE
# =========================================
# Origem: credenciais preservadas do Evangelho Digital (TiagoIA-UX/evangelho-digital)
# Copie para .env.local e preencha os valores reais.
# Documentação completa: docs/CREDENCIAIS_AMBIENTE.md
# Banco RCT: Neon projeto "rct-plataforma" (NÃO usar blog-terapia)

# ===== App / Segurança =====
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=REDACTED_cron_secret_aleatorio_min_32_caracteres
ADMIN_PASSWORD=REDACTED_senha_admin_bem_forte

# ===== Banco de dados (Neon PostgreSQL) =====
DATABASE_URL=REDACTED_DATABASE_URL

# ===== Groq (conteúdo + análise de ressonância) =====
GROQ_API_KEY=

# ===== Neon Auth (Google Login) =====
NEON_AUTH_BASE_URL=https://seu-projeto.neonauth.sa-east-1.aws.neon.tech/neondb/auth
NEON_AUTH_COOKIE_SECRET=seu_cookie_secret_min_32_caracteres

# ===== Mercado Pago (assinatura premium RCT) =====
MERCADOPAGO_ACCESS_TOKEN=
MERCADO_PAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_PUBLIC_KEY=
MERCADO_PAGO_PUBLIC_KEY=

# ===== Google Calendar (agendamento — opcional) =====
GOOGLE_CALENDAR_EMAIL=
GOOGLE_CALENDAR_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_TIMEZONE=America/Sao_Paulo

# ===== Telegram Bot =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
ENABLE_TELEGRAM_CONVITES=true
ENABLE_ADMIN_ALERTS=true

# ===== Upstash Redis =====
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== Resend (emails transacionais) =====
RESEND_API_KEY=

# ===== Contato público =====
NEXT_PUBLIC_CONTATO_EMAIL=contato@rct.com.br

# ===== Doação PIX (página /contribuir) =====
NEXT_PUBLIC_PIX_CHAVE=
NEXT_PUBLIC_PIX_TITULAR=
NEXT_PUBLIC_PIX_CIDADE=
NEXT_PUBLIC_MEI_RAZAO_SOCIAL=Seu Nome MEI
NEXT_PUBLIC_MEI_CNPJ=00.000.000/0001-00

# ===== RCT Config =====
RCT_PLATAFORMA_URL=https://rct.com.br
DIAGNOSTICO_SCORE_MINIMO_ESCOLHIDO=80
